{
  "trash_id": "152aec63ad8f4c7340446b202a47f409",
  "name": "HDR exclusif",
  "description": "Détection HDR exclusif (sans Dolby Vision, sans HDR10+) pour éviter le cumul des types HDR. SF-custom.",
  "specifications": [
    {
      "name": "HDR / HDR10",
      "implementation": "ReleaseTitleSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "value": "\\b(HDR(?:10)?)\\b"
      }
    },
    {
      "name": "No HDR10+",
      "implementation": "ReleaseTitleSpecification",
      "negate": true,
      "required": true,
      "fields": {
        "value": "\\b(HDR10(?=[+]|P(lus)?))"
      }
    },
    {
      "name": "No DV",
      "implementation": "ReleaseTitleSpecification",
      "negate": true,
      "required": true,
      "fields": {
        "value": "\\b(dv|dovi|dolby[ .]?v(ision)?)\\b"
      }
    }
  ]
}